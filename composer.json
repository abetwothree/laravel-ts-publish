{
    "name": "abetwothree/laravel-ts-publish",
    "description": "Create TypeScript declaration types from your PHP models, enums, and other cast classes",
    "keywords": [
        "abetwothree",
        "laravel",
        "laravel-ts-publish"
    ],
    "type": "library",
    "homepage": "https://github.com/abetwothree/laravel-ts-publish",
    "license": "MIT",
    "authors": [
        {
            "name": "Abraham Arango",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "composer/class-map-generator": "^1.7",
        "illuminate/contracts": "^11.0||^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "archtechx/enums": "^1.1",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^10.0.0||^9.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "AbeTwoThree\\LaravelTsPublish\\": "src/",
            "AbeTwoThree\\LaravelTsPublish\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AbeTwoThree\\LaravelTsPublish\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/",
            "Workbench\\Accounting\\": "workbench/modules/Accounting/",
            "Workbench\\Blog\\": "workbench/modules/Blog/",
            "Workbench\\Shipping\\": "workbench/modules/Shipping/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare",
            "@composer run prepare"
        ],
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse --verbose --ansi",
        "test": "vendor/bin/pest",
        "test-cov": "export XDEBUG_MODE=coverage && vendor/bin/pest --coverage --coverage-clover coverage.xml",
        "test-cov-html": "export XDEBUG_MODE=coverage && vendor/bin/pest --coverage-html coverage",
        "test-cov-xml": "export XDEBUG_MODE=coverage && vendor/bin/pest --coverage-xml coverage",
        "format": "vendor/bin/pint",
        "lint": [
            "@php vendor/bin/pint --ansi",
            "@php vendor/bin/phpstan analyse --verbose --ansi"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AbeTwoThree\\LaravelTsPublish\\LaravelTsPublishServiceProvider"
            ],
            "aliases": {
                "LaravelTsPublish": "AbeTwoThree\\LaravelTsPublish\\Facades\\LaravelTsPublish"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
